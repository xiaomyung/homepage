[Unit]
Description=Football Evolution API
After=network.target

[Service]
Type=simple
WorkingDirectory=/srv/services/web/homepage/games/football/api
ExecStart=/usr/bin/node --disable-warning=ExperimentalWarning /srv/services/web/homepage/games/football/api/broker.mjs
Restart=always
RestartSec=3
User=apollo

[Install]
WantedBy=multi-user.target
